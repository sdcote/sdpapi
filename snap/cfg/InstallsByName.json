{
  "RtwJob":{

    "Vault": { "filename": "[#$sys.app.home#][#$sys.file.separator#]sdp.vault", "password": "[#$env.vault.password#]" },

    "Reader": {
      "class": "ServiceDeskApiReader",
      "clientId": "[#Vault.get(AssetAutomation,Username)#]",
      "clientSecret": "[#Vault.get(AssetAutomation,Password)#]",
      "clientToken": "[#Vault.get(AssetAutomation,Token)#]",
      "endpoint": "/software_installations",
      "resultField": "software_installations",
      "batch": 100,
      "flatten": true,
      "searchCriteria": { "field": "software.name", "condition": "contains", "value": "[#$cmd.arg.1#]" },
      "searchCriteria2": { "field": "software.name", "condition": "contains", "value": "WinMerge" },
      "fieldsRequired": [ "software.name", "software.id", "workstation.name", "workstation.id", "location"],
      "fieldsRequiredALL": ["architecture","asset.asset_tag","asset.department.name","asset.id","asset.name","asset.product.name","asset.product_type.name","asset.service_tag","asset.site.name","asset.state.name","id","installation_date","installation_path","is_parent_suite","last_usage_time","service_pack","software.category.name","software.id","software.is_parent_suite","software.manufacturer.name","software.name","software.type.name","usage_status","version"]
    },

    "Writer": { "class": "ConsoleWriter", "format": "json" },
    "Writer": { "class": "CsvWriter", "target": "installs_by_name.csv", "header": true },

    "Logging": {
      "StandardError": { "categories": "warn, error, fatal" },
      "StandardOutput": { "categories": "debug, trace, info, notice", "enabled": false }
    }

  }

}